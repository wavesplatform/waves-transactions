{
  "name": "@waves/waves-transactions",
  "version": "4.3.11",
  "description": "Build and sign(multi-sign) transactions for Waves blockchain.",
  "keywords": [
    "waves",
    "crypto",
    "transactions",
    "protocol",
    "binary",
    "cryptography",
    "signature"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prepare": "npm run build",
    "postversion": "npm publish",
    "build-docs": "typedoc --options typedoc.config.cjs --entryPointStrategy resolve ./src/index.ts --out docs && touch docs/.nojekyll",
    "postpublish": "git push origin head",
    "build": "ts-node build/build.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest"
  },
  "files": [
    "/dist",
    "/src"
  ],
  "author": {
    "name": "wavesplatform"
  },
  "contributors": [
    {
      "name": "Sergey B",
      "email": "siemarell@gmail.com"
    },
    {
      "name": "Yuriy Naydenov",
      "email": "ebceu44@gmail.com"
    }
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "jsdoc-to-markdown": "^9.1.3",
    "ncp": "^2.0.0",
    "preprocess": "^3.2.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.2",
    "typescript-json-schema": "^0.67.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wavesplatform/waves-transactions.git"
  },
  "dependencies": {
    "@waves/marshall": "^0.15.0-beta.1",
    "@waves/protobuf-serialization": "1.6.1-snapshot.1",
    "@waves/ts-lib-crypto": "file:../ts-lib-crypto",
    "@waves/ts-types": "^1.3.1",
    "axios": "^1.13.5",
    "long": "^5.3.2",
    "protobufjs": "7.5.4"
  }
}
