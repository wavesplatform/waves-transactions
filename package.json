    "test-exclude": "^8.0.0"
  },
  "dependencies": {
    "@waves/marshall": "^0.15.0-beta.1",
    "@waves/protobuf-serialization": "^1.6.1",
    "@waves/ts-lib-crypto": "^1.5.1",
    "@waves/ts-types": "^1.3.1",
    "axios": "^1.13.5",
    "long": "^5.3.2",
    "protobufjs": "^7.5.4"
  }
